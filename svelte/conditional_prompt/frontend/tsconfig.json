{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "types": ["svelte", "svelte2tsx/svelte-shims-v4", "svelte2tsx/svelte-jsx-v4"]
  },
  "include": ["Index.svelte", "**/*.d.ts"],
  "exclude": ["node_modules"]
}
